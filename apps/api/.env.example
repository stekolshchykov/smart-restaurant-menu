DATABASE_URL=postgres://postgres:postgres@localhost:5433/digital_menu
DATABASE_URL_TEST=postgres://postgres:postgres@localhost:5433/digital_menu_test
PORT=3001
JWT_SECRET=change-me-to-a-long-secret-at-least-64-characters-long-for-hs256
JWT_ACCESS_EXPIRY_MINUTES=15
JWT_REFRESH_EXPIRY_DAYS=7
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
APP_ENV=development
WEB_ORIGIN=http://localhost:5173
API_ORIGIN=http://localhost:3001
# Optional: absolute or relative path for uploaded images (defaults to ./uploads).
# UPLOAD_DIR=/app/uploads

# Production notes:
# - Copy this file to apps/api/.env for local development.
# - In Docker Compose the root .env.example file is used instead.
# - Set JWT_SECRET to a cryptographically random string >= 32 characters.
# - Set ALLOWED_ORIGINS to a comma-separated list of trusted frontend origins.
# - Use HTTPS values for WEB_ORIGIN and API_ORIGIN in production.
# - APP_ENV should be "production" when deployed.
