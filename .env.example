# PostgreSQL (used by Docker Compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=digital_menu

# Docker Compose exposed ports and origins (production-like deployment)
# The web container runs the Node adapter production build on WEB_PORT.
API_PORT=3001
WEB_PORT=3000
WEB_ORIGIN=http://localhost:3000
API_ORIGIN=http://localhost:3001
ALLOWED_ORIGINS=http://localhost:3000

# API runtime config (used by the api container)
JWT_SECRET=change-me-to-a-long-secret-at-least-64-characters-long-for-hs256
JWT_ACCESS_EXPIRY_MINUTES=15
JWT_REFRESH_EXPIRY_DAYS=7
APP_ENV=production

# Local development values (not used by Docker Compose; copy apps/api/.env.example instead)
# DATABASE_URL=postgres://postgres:postgres@localhost:5433/digital_menu
# DATABASE_URL_TEST=postgres://postgres:postgres@localhost:5433/digital_menu_test

# MinIO / S3-compatible object storage (optional; when set, image uploads go to S3).
# STORAGE_ENDPOINT=http://185.237.204.37:9000
# STORAGE_BUCKET=digital-menu-uploads
# STORAGE_ACCESS_KEY=
# STORAGE_SECRET_KEY=
# STORAGE_REGION=us-east-1
# STORAGE_USE_PATH_STYLE=true

# Production notes:
# - Generate a strong JWT_SECRET (>= 32 chars) and never commit it.
# - Use HTTPS origins in production.
# - ALLOWED_ORIGINS must include WEB_ORIGIN and any other allowed frontends.
# - DATABASE_URL_TEST is only required for integration tests, not runtime.
# - Optional: set UPLOAD_DIR to an absolute path for uploaded file storage.
# - Set STORAGE_* to use MinIO/S3 instead of local disk for image uploads.
